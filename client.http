### ===== MESSAGE ENDPOINTS =====
### Replace TOKEN and IDs with actual values

### 1. Create a new message in a conversation
POST http://localhost:3000/api/conversations/1/messages
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MywidXNlcm5hbWUiOiJhemt5Iiwicm9sZSI6InVzZXIiLCJpYXQiOjE3NzcxNzcxMDEsImV4cCI6MTc3Nzc4MTkwMX0.HqGiS7MuRqitUnCQZTU0Biy8f9d_8yItY40khXMnGhc

{
  "content": "Halo, apa itu AI?",
  "senderType": "user"
}

###
### 2. Create AI response message
POST http://localhost:3000/api/conversations/1/messages
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MywidXNlcm5hbWUiOiJhemt5Iiwicm9sZSI6InVzZXIiLCJpYXQiOjE3NzcxNzcxMDEsImV4cCI6MTc3Nzc4MTkwMX0.HqGiS7MuRqitUnCQZTU0Biy8f9d_8yItY40khXMnGhc

{
  "content": "AI (Artificial Intelligence) adalah cabang ilmu komputer yang fokus pada penciptaan sistem yang dapat melakukan tugas-tugas yang biasanya memerlukan kecerdasan manusia.",
  "senderType": "ai"
}

###
### 3. Get all messages for a conversation (with pagination)
GET http://localhost:3000/api/conversations/1/messages?skip=0&take=20
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MywidXNlcm5hbWUiOiJhemt5Iiwicm9sZSI6InVzZXIiLCJpYXQiOjE3NzcxNzcxMDEsImV4cCI6MTc3Nzc4MTkwMX0.HqGiS7MuRqitUnCQZTU0Biy8f9d_8yItY40khXMnGhc

